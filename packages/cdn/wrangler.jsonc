{
	"name": "venz-cdn",
	"main": "src/worker.ts",
	"compatibility_date": "2025-07-12",
	"routes": [
		{
			"pattern": "cdn.venz.dev",
			"custom_domain": true
		}
	],
	"containers": [
		{
			"class_name": "CdnContainer",
			"image": "../../Containerfile",
			"instance_type": "basic",
			"max_instances": 1
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "CdnContainer",
				"name": "CDN_CONTAINER"
			}
		]
	},
	"migrations": [
		{
			"new_sqlite_classes": ["CdnContainer"],
			"tag": "v1"
		}
	],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
	}
}
